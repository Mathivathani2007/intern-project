rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isManager() {
      return getUserRole() == 'manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && isAdminOrManager();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdminOrManager();
    }

    match /socialPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /healthAppointments/{appointmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdminOrManager();
    }

    match /enrollments/{enrollmentId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /crmLeads/{leadId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /analyticsEvents/{eventId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
    }
  }
}
